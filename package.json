{
  "name": "ai-project-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "npm --prefix frontend run dev",
    "backend": "node backend/index.js",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "test": "vitest run && npm --prefix frontend run test",
    "test:backend": "vitest run",
    "test:frontend": "npm --prefix frontend run test",
    "test:watch": "vitest",
    "lint": "eslint . && npm --prefix frontend run lint",
    "lint:fix": "eslint . --fix && npm --prefix frontend run lint:fix",
    "install:all": "npm install && npm --prefix frontend install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "supertest": "^7.2.2",
    "vitest": "^3.2.4"
  }
}
